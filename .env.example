# .env.example
# Nunca comite seu .env real!

DISCORD_TOKEN=COLE_SEU_TOKEN_AQUI

# Opcional
COMMAND_PREFIX=!
# Intervalo da varredura (em minutos). Ex.: 360 = 6 em 6 horas
LOOP_MINUTES=360
LOG_LEVEL=INFO

# Ingestão segura (anti-bloqueio/anti-scraping agressivo)
MAX_CONCURRENT_FEEDS=5
FEED_TIMEOUT_SECONDS=40
RSS_MAX_RETRIES=3
RSS_RETRY_BACKOFF_BASE=1.0
# 0 = sem limitação de quantidade por feed
MAX_ENTRIES_PER_FEED=0
MAX_NEWS_AGE_DAYS=7
# 1 = exige data no feed (recomendado para evitar backfill antigo)
REQUIRE_ENTRY_DATE=1
FEED_FETCH_JITTER_MIN=0.3
FEED_FETCH_JITTER_MAX=1.2
STRICT_GENERIC_YOUTUBE=1

# Fallback seguro de imagem HTML (og:image/twitter:image)
# 0 = desativado (padrão), 1 = ativado
ENABLE_OG_IMAGE_FALLBACK=0
# Timeout curto para fallback HTML
OG_IMAGE_TIMEOUT_SECONDS=5
# Máximo de bytes lidos do HTML (evita download grande)
OG_IMAGE_MAX_BYTES=262144
# Whitelist de domínios permitidos para fetch do fallback (csv)
# Exemplo: ign.com,gamespot.com,polygon.com
OG_IMAGE_ALLOWED_DOMAINS=

# Segurança do Servidor Web
# WEB_AUTH_TOKEN: Token para autenticação no servidor web (recomendado para produção)
# WEB_HOST: Host do servidor web (127.0.0.1 = apenas localhost, 0.0.0.0 = todos os IPs)
# WEB_PORT: Porta do servidor web
WEB_AUTH_TOKEN=
WEB_HOST=127.0.0.1
WEB_PORT=8080
